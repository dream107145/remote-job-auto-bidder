# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABVASE_PASSWORD=6E5y7bwLNJF0fudo

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENCRYPTION_SECRET=generate-a-long-random-secret-for-indeed-credentials

# Indeed (optional — users can also save credentials in Settings)
INDEED_HEADLESS=true
# Job sync uses a real browser by default; headless mode is blocked by Indeed/Cloudflare
# INDEED_SCRAPE_HEADLESS=true
# Keep Chromium inside node_modules so Vercel serverless functions can find it
PLAYWRIGHT_BROWSERS_PATH=0

# Crypto (NowPayments)
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-ipn-secret

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=sk-...

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
